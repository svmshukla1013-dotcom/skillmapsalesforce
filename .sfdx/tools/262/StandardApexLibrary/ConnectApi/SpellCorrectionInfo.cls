/**
 * Spell correction information for object search.
 */
global class SpellCorrectionInfo {

  global SpellCorrectionInfo() {}

  /**
   * Specifies corrected query.
   */
  global String correctedQuery;

  /**
   * Specifies whether some non-corrected results were returned ( true ) or not ( false ).
   */
  global Boolean hasNonCorrectedResults;

  global Object clone() {}

}