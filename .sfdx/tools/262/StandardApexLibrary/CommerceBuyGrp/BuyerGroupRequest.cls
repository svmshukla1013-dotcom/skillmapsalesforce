/**
 * Contains methods to retrieve account and store details used to identify the buyer groups associated with a user.
 */
global class BuyerGroupRequest {

  global BuyerGroupRequest() {}

  /**
   * Specifies the multiple key-value pair representing guest UUID cookie for each store. Generated by the client as a unique device identifier where siteId is the 15-digit ID for the site associated with the webstore.
   */
  global String guest_uuid_essential_{siteId};

  /**
   * Indicates whether the user in context is a guest user ( true ) or an authenticated user ( false ).
   */
  global Boolean isGuestUser;

  /**
   * Specifies the user's locale.
   */
  global String locale;

  global String getAccountId() {}

  global String getStoreId() {}

  global Map<String,Object> getRequestContextParameters() {}

  global Object clone() {}

}