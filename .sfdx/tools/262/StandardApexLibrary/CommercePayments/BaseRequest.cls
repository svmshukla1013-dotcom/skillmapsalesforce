/**
 * BaseRequest is extended by all the request classes.
 */
global class BaseRequest {

  global BaseRequest() {}

  /**
   * Used for testing.
   * @param AdditionalData Contains additional data that may be required for a payment request. The additionalData object consists of key-value pairs. You can retrieve the additionalData object from the request object: Map<String, String> additionalData=request.additionalData
   * @param IdempotencyKey Unique value that's generated by a client and sent to the server in the request. The server stores the value and uses the it to keep track of the request status.
   */
  global void BaseRequest(String AdditionalData, Map<String, String> IdempotencyKey) {}

  global Object clone() {}

}