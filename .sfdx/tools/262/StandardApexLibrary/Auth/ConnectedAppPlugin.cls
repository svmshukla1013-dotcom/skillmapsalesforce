/**
 * Contains methods for extending the behavior of a connected app, for example, customizing how a connected app is invoked depending on the protocol used. This class gives you more control over the interaction between Salesforce and your connected app.
 */
global class ConnectedAppPlugin {

  global ConnectedAppPlugin() {}

  /**
   * Deprecated and available only in API versions 35.0 and 36.0. As of version 37.0, use authorize(userId, connectedAppId, isAdminApproved, context) instead.
   * @param userId The 15-character ID of the user attempting to use the connected app.
   * @param connectedAppId The 15-character ID of the connected app.
   * @param isAdminApproved The approval state of the specified user when the connected app requires approval.
   * @return Boolean
   */
  global Boolean authorize(Id userId, Id connectedAppId, Boolean isAdminApproved) {}

  /**
   * Deprecated and available only in API versions 35.0 and 36.0. As of version 37.0, use authorize(userId, connectedAppId, isAdminApproved, context) instead.
   * @param userId The 15-character ID of the user attempting to use the connected app.
   * @param connectedAppId The 15-character ID of the connected app.
   * @param isAdminApproved The approval state of the specified user when the connected app requires approval.
   * @param context 
   * @return Boolean
   */
  global Boolean authorize(Id userId, Id connectedAppId, Boolean isAdminApproved, Auth.InvocationContext context) {}

  /**
   * Deprecated and available only in API versions 35.0 and 36.0. As of version 37.0, use customAttributes(userId, connectedAppId, formulaDefinedAttributes, context) instead.
   * @param userId The 15-character ID of the user attempting to use the connected app.
   * @param connectedAppId The 15-character ID of the connected app.
   * @param formulaDefinedAttributes A map of the new set of attributes from the UserInfo endpoint (OAuth) or from a SAML assertion. For more information, see The UserInfo Endpoint in the online help.
   * @return Map<String,String>
   */
  global Map<String,String> customAttributes(Id userId, Id connectedAppId, Map<String,String> formulaDefinedAttributes) {}

  /**
   * Deprecated and available only in API versions 35.0 and 36.0. As of version 37.0, use customAttributes(userId, connectedAppId, formulaDefinedAttributes, context) instead.
   * @param userId The 15-character ID of the user attempting to use the connected app.
   * @param connectedAppId The 15-character ID of the connected app.
   * @param formulaDefinedAttributes A map of the new set of attributes from the UserInfo endpoint (OAuth) or from a SAML assertion. For more information, see The UserInfo Endpoint in the online help.
   * @param context 
   * @return Map<String,String>
   */
  global Map<String,String> customAttributes(Id userId, Id connectedAppId, Map<String,String> formulaDefinedAttributes, Auth.InvocationContext context) {}

  /**
   * Modifies the XML generated by the Salesforce SAML Identity Provider (IDP) before it’s sent to the service provider.
   * @param authSession The attributes for the authorized user’s session. The map includes the 15-character ID of the authorized user who’s accessing the connected app.
   * @param connectedAppId The 15-character ID of the connected app.
   * @param samlResponse Contains the SAML XML response generated by the IDP.
   * @return dom.XmlNode
   */
  global dom.XmlNode modifySAMLResponse(Map<String,String> authSession, Id connectedAppId, dom.XmlNode samlResponse) {}

  /**
   * Deprecated and available only in API versions 35.0 and 36.0. As of version 37.0, use refresh(userId, connectedAppId, context) instead.
   * @param userId The 15-character ID of the user requesting the refresh token.
   * @param connectedAppId The 15-character ID of the connected app.
   */
  global void refresh(Id userId, Id connectedAppId) {}

  /**
   * Deprecated and available only in API versions 35.0 and 36.0. As of version 37.0, use refresh(userId, connectedAppId, context) instead.
   * @param userId The 15-character ID of the user requesting the refresh token.
   * @param connectedAppId The 15-character ID of the connected app.
   * @param context 
   */
  global void refresh(Id userId, Id connectedAppId, Auth.InvocationContext context) {}

  global Object clone() {}

  global Map<String,String> customAttributes(Id userId, Map<String,String> formulaDefinedAttributes) {}

}